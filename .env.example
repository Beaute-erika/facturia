# ─────────────────────────────────────────────
# Facturia — Variables d'environnement
# Copier ce fichier en .env.local et remplir les valeurs
# ─────────────────────────────────────────────

# ── Supabase ──────────────────────────────────
# Récupérer sur https://app.supabase.com → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://votre-projet.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=votre-anon-key
SUPABASE_SERVICE_ROLE_KEY=votre-service-role-key

# ── Anthropic (Agent IA) ──────────────────────
# Récupérer sur https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ── Stripe (Paiements & Abonnements) ─────────
# Clés API — https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
# Webhook secret — https://dashboard.stripe.com/webhooks
# Événements requis : checkout.session.completed, customer.subscription.created,
#                     customer.subscription.updated, customer.subscription.deleted,
#                     invoice.payment_failed, invoice.payment_succeeded
STRIPE_WEBHOOK_SECRET=whsec_...
# Price IDs des abonnements — https://dashboard.stripe.com/products
# Créer un produit "Facturia Pro" avec un prix récurrent mensuel à 29€
STRIPE_PRICE_PRO_MONTHLY=price_...
# Créer un produit "Facturia Business" avec un prix récurrent mensuel à 49€
STRIPE_PRICE_BUSINESS_MONTHLY=price_...

# ── Email (envoi factures / relances) ─────────
# Exemple avec Resend (https://resend.com)
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@votre-domaine.fr

# ── App ───────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://votre-domaine.com
